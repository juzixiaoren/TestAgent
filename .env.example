OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 命令执行 shell：auto / cmd / powershell / pwsh / bash / sh
EXECUTE_COMMAND_SHELL=auto

# 终端显示：建议 Windows Terminal / PowerShell 7 / VS Code Terminal 使用颜色
AGENT_COLOR_OUTPUT=true
AGENT_RENDER_MARKDOWN=true
PLAIN_TEXT_OUTPUT=true

# 技能上下文模式：dynamic 只注入 skill 索引，按需 read_file 读取全文；full 启动时注入完整 skill 正文
SKILL_CONTEXT_MODE=dynamic
